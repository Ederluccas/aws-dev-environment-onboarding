# Copie este arquivo para config/.env e atualize os valores.

# Perfil AWS para uso local
AWS_PROFILE=default

# Região padrão da AWS
AWS_REGION=us-east-1

# Formato de saída da AWS (json, yaml, text, table)
AWS_OUTPUT=json

# Defina como true para pular ferramentas opcionais no setup
SKIP_DEV_TOOLS=false

# Defina como true para pular configuração do VS Code no setup
SKIP_VSCODE=false

# Defina como true para instalar apenas extensões (quando o comando 'code' já existe)
VSCODE_EXTENSIONS_ONLY=false

# Perfil de extensões do VS Code: aws-devops ou full
VSCODE_PROFILE=aws-devops

# Defina como true para pular configuração de terminal (zsh + oh-my-zsh)
SKIP_TERMINAL_SETUP=false

# Defina como true para tentar configurar zsh como shell padrão
ZSH_SET_DEFAULT=false
